
<style>
    .collection-list-container-{{ section.id }} {
        width:90vw;
        display: grid;
        grid-template-columns: 1fr 1fr 1fr 1fr;
        gap : 1rem;
        justify-content: center;
        box-sizing: border-box;
        margin-left : auto;
        margin-right: auto;

    }

    .collection-image-{{ section.id }}{
     width: 100%;
     height: auto;
     object-fit: cover;
     border-radius: 50%;
     border: 3px solid black;
    
    }


</style>




<div class="collection-list-container-{{ section.id }}">
    <h4> {{ section.settings.collection_list_heading }}</h4>
    {% for block in section.blocks %}
    <a class="collection-link-{{ section.id }}" href="{{block.settings.collection_link}}" target="_blank">
        <img class="collection-image-{{ section.id }}" 
             src="{{ block.settings.collection_image |image_url: width: 500 , height:500 }}" 
             alt="Collection Image" />

    </a>
    {% endfor %}

</div>



{%  schema %}
{
    "name": "Collection List GM",
    "settings": [
        {  
        "type": "richtext",
        "id": "collection_list_heading",
        "label": "Collection Heading",
        "default": "<h4> Explore Our Best Sellers </h4>"
        }
    ],
    "blocks": [
      {
     "type": "collection-list",
      "name": "Collection List",
      "settings": [
            {
                "type": "image_picker",
                "id": "collection_image",
                "label": "Select Image"
            
            },
            {
            "type" : "url",
            "id": "collection_link",
            "label": "Collection Link"
            
            }

      ]

     }

    ],
    "presets": [
        {
        "name": "Collection List GM"
        }
    ]
}

{% endschema %}