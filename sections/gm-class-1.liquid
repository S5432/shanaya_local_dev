<style>
  h1{
padding-top: {{ section.settings.padding_top  }}rem;
font-size: {{ section.settings.headingfont_size }}px;
text-align: {{ section.settings.heading_alignment }};

}
</style>

{{ section.settings.radio }}

<div class="page-width">
    {%  if section.settings.show_heading == true %}
        <h1>{{ section.settings.heading_text  }}</h1>
    {%  endif %}

    
    <p>{{ section.settings.paragraph_text }} </p>
    {% if section.settings.mylucky_number>0 %}
        {{ section.settings.mylucky_number }}
    {% endif %}

</div>


{% schema %}

{
    "name": "Class 1",
    "settings": [
        {
        "type": "text",
        "id": "heading_text",
        "label": "Heading"
        },
        {
            "type": "textarea",
            "id": "paragraph_text",
            "label": "White Paragraph",
            "default": "Tell your brand story here"
        
        },
        {
        "type": "number",
        "id": "mylucky_number",
        "label": "Lucky Number",
        "default": 1234
        },
        {
        "type": "range",
        "id": "padding_top",
        "label": "Padding Top",
        "min": 1,
        "max": 100,
        "step": 1,
        "unit": "rem",
        "default": 2
        
        },
        {
        "type": "range",
        "id": "headingfont_size",
        "label": "Heading Font Size",
        "min": 1,
        "max": 100,
        "step": 1,
        "unit": "px",
        "default":15

         },
         {
        "type": "select",
        "id": "heading_alignment",
        "label": "Heading Alignment",
        "options": [
            {
            "value": "left",
            "label": "Left Align"

            },
            {
            "value": "center",
            "label": "Center Align"
            },
            {
            "value": "right",
            "label": "Right Align"
            }
        ],
        "default": "center"
        },
        {
        "type": "checkbox",
        "id": "show_heading",
        "label": "Show Heading",
        "default": true
        },
        {
        "type": "radio",
        "id": "radio",
        "label": "Radio",
        "options": [
            {
            "value": "This video is Good",
            "label": "Good"
            },
            {
            "value": "This video is Bad",
            "label": "Bad"
            }
        ]
        }
    ],
    "blocks": [],
    "presets": [
        {
        "name": "Class 1"
        }
    ]

}


{% endschema %}